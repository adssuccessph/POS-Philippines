{
  "name": "pos-philippines-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:schema:local": "wrangler d1 execute pos-philippines-db --local --file=schema.sql",
    "db:seed:local": "wrangler d1 execute pos-philippines-db --local --file=seed.sql",
    "db:schema:remote": "wrangler d1 execute pos-philippines-db --remote --file=schema.sql",
    "db:seed:remote": "wrangler d1 execute pos-philippines-db --remote --file=seed.sql"
  },
  "devDependencies": {
    "wrangler": "^4.111.0"
  }
}
